config_version=5

[application]

config/name="School Saga"
config/description="Technical walking skeleton for School Saga."
run/main_scene="res://scenes/locations/home_morning.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

SceneTransition="*res://src/core/scene_transition.gd"
SaveService="*res://src/core/save_service.gd"

